APP_ENV=dev
APP_DEBUG=true
TRACE_STDOUT=true

DB_PATH=.data/agent.db
VEC_EXTENSION=sqlite_vec

LLM_PROVIDER=ollama
LLM_MODEL=gpt-oss:latest
LLM_TEMPERATURE=0.2

EMBED_PROVIDER=ollama
EMBED_MODEL=mxbai-embed-large
EMBED_DIMS=1024

SKILLS_ENABLED=builtins.time

AGENT_WORKSPACE=workspace

# Planner policy (central governance over skill-declared metadata)
ALLOW_TOOLS_BY_DEFAULT=true
ALLOW_NETWORK=true
ALLOW_FILESYSTEM_READ=true
ALLOW_FILESYSTEM_WRITE=false
DENY_TOOLS=
ALLOW_TAGS=
DENY_TAGS=
DENY_SCOPES=
DENY_RISK=
TOOL_TIMEOUTS=
ENFORCE_TOOL_CONFIRMATION=false
